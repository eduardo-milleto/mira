# conexao com o postgres (local via docker-compose)
DATABASE_URL="postgresql://mira:mira@localhost:5432/mira?schema=public"

# segredo pra assinar os JWT (gere um aleatorio em prod)
JWT_SECRET="troque-isto-por-um-segredo-bem-grande-e-aleatorio"

# origem do frontend permitida no CORS
CORS_ORIGIN="http://localhost:5173"

# dominio dos cookies em prod (ex: ".mirafinance.app") pra valerem entre front e api.
# em dev deixe vazio (host-only no localhost)
COOKIE_DOMAIN=""

# porta da api
PORT=3333

# ambiente: development | production
NODE_ENV=development

# chave da API do Gemini (opcional) — sem ela a rota /insights fica indisponivel
GEMINI_API_KEY=""
