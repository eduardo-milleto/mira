# conexao com o postgres (local via docker-compose)
DATABASE_URL="postgresql://mira:mira@localhost:5432/mira?schema=public"

# segredo pra assinar os JWT (gere um aleatorio em prod)
JWT_SECRET="troque-isto-por-um-segredo-bem-grande-e-aleatorio"

# origem do frontend permitida no CORS (e usada tambem como checagem de CSRF por Origin)
CORS_ORIGIN="http://localhost:5173"

# porta da api
PORT=3333

# ambiente: development | production
NODE_ENV=development

# chave da API do Gemini (opcional) — sem ela a rota /insights fica indisponivel
GEMINI_API_KEY=""

# credenciais do Pluggy (Open Finance, opcionais) — sem elas a aba Saldo no banco
# nao consegue conectar/sincronizar. pegue no dashboard: https://dashboard.pluggy.ai
PLUGGY_CLIENT_ID=""
PLUGGY_CLIENT_SECRET=""
