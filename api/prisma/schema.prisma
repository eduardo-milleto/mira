generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  expenses           Expense[]
  creditCards        CreditCard[]
  incomeSources      IncomeSource[]
  investments        Investment[]
  projectionSettings ProjectionSettings?
  personalExpenses   PersonalExpense[]
  categoryLimits     CategoryLimit[]
  spendingProfile    SpendingProfile?
  advisorMessages    AdvisorMessage[]
  extras             Extra[]
  cofreMovements     CofreMovement[]
  monthCloses        MonthClose[]
  cofreState         CofreState?
  investmentEvents   InvestmentEvent[]
  insightsCache      InsightsCache[]
  expenseAreaMap     ExpenseAreaMap[]
  bankConnection     BankConnection?
  bankSnapshots      BankBalanceSnapshot[]

  @@map("users")
}

// gasto mensal avulso cadastrado pelo usuario (ex: "Aluguel AP")
model Expense {
  id        String   @id @default(uuid())
  userId    String
  name      String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("expenses")
}

// cartao de credito do usuario; entra no gasto mensal so quando includeInMonthly = true
model CreditCard {
  id               String   @id @default(uuid())
  userId           String
  name             String // apelido (ex: "Nubank Roxinho")
  bank             String? // banco emissor (Nubank, Inter...); opcional se a bandeira for informada
  brand            String? // bandeira do cartao (Visa, Mastercard, Elo...); opcional se o banco for informado
  avgMonthlySpend  Decimal  @db.Decimal(12, 2)
  includeInMonthly Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("credit_cards")
}

// fonte de renda do usuario usada nas projecoes; itens com startYear no futuro
// sao "novas rendas" que so passam a contar a partir daquele ano
model IncomeSource {
  id              String       @id @default(uuid())
  userId          String
  name            String // ex: "Salario", "Aluguel + Empresa"
  monthlyAmount   Decimal      @db.Decimal(12, 2)
  annualGrowthPct Decimal      @default(0) @db.Decimal(5, 2) // crescimento esperado ao ano
  startYear       Int? // null = ja ativa; ano futuro = renda que ainda vai comecar
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps           IncomeStep[]

  @@index([userId])
  @@map("income_sources")
}

// valor mensal definido pra um ano futuro especifico (ex: salario sobe pra X em 2027).
// sobrescreve o crescimento percentual a partir daquele ano. editavel pela tela de Ganhos
model IncomeStep {
  id             String       @id @default(uuid())
  incomeSourceId String
  year           Int
  monthlyAmount  Decimal      @db.Decimal(12, 2)
  createdAt      DateTime     @default(now())
  income         IncomeSource @relation(fields: [incomeSourceId], references: [id], onDelete: Cascade)

  @@unique([incomeSourceId, year])
  @@index([incomeSourceId])
  @@map("income_steps")
}

// ativo que compoe o patrimonio do usuario; classificado por categoria (texto livre).
// expectedReturnPct e notes alimentam a projecao por IA (premissa de rendimento por ativo)
model Investment {
  id                String   @id @default(uuid())
  userId            String
  kind              String   @default("investimento") // "investimento" | "patrimonio"
  name              String // ex: "Apto Centro", "Tesouro IPCA", "Carteira de acoes"
  category          String // classificacao livre (ex: "Imovel", "Renda fixa", "Trade")
  value             Decimal  @db.Decimal(12, 2) // valor atual
  expectedReturnPct Decimal? @db.Decimal(5, 2) // % ao ano esperado; null = ativo nao rende na projecao (0%), IA nao infere
  notes             String? // premissa livre por tipo de ativo (ex: "valoriza 8%/ano + aluguel")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  events            InvestmentEvent[]
  cofreMovements    CofreMovement[]

  @@index([userId])
  @@map("investments")
}

// premissas globais da projecao (1 linha por usuario)
model ProjectionSettings {
  id            String   @id @default(uuid())
  userId        String   @unique
  returnRatePct Decimal  @default(10) @db.Decimal(5, 2) // rendimento ao ano da sobra investida
  horizonYears  Int      @default(5) // quantos anos projetar
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("projection_settings")
}

// gasto pessoal/discricionario: cada compra e uma linha datada com categoria.
// soma do mes corrente entra no gasto mensal e e o que a consultora IA analisa.
model PersonalExpense {
  id        String   @id @default(uuid())
  userId    String
  name      String // ex: "iFood", "Tenis Nike"
  category  String // categoria discricionaria (Lazer, Delivery, Compras, etc)
  amount    Decimal  @db.Decimal(12, 2)
  spentAt   DateTime @db.Date // data da compra (sem horario; usada pra somar por mes)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, spentAt])
  @@map("personal_expenses")
}

// limite mensal por categoria de gasto pessoal. source diz se foi a IA que sugeriu
// ou o usuario que definiu/ajustou. 1 limite por categoria por usuario.
model CategoryLimit {
  id        String   @id @default(uuid())
  userId    String
  category  String
  amount    Decimal  @db.Decimal(12, 2) // teto mensal
  source    String   @default("user") // "user" | "ai"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("category_limits")
}

// contexto/gatilhos que o usuario escreve pra IA considerar (1 linha por usuario).
// opcional: a IA tambem infere padroes pelo proprio log de compras.
model SpendingProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  triggers  String   @db.Text // texto livre: gatilhos, objetivos, contexto do periodo
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("spending_profiles")
}

// historico do chat com a consultora IA (uma linha por mensagem, user ou assistant)
model AdvisorMessage {
  id        String   @id @default(uuid())
  userId    String
  role      String // "user" | "assistant"
  content   String   @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("advisor_messages")
}

// movimento pontual de um mes (nao recorrente): ganho extra (bonus, freela, venda)
// ou gasto extra (despesa inesperada). a soma do mes ajusta os totais daquele mes.
model Extra {
  id          String   @id @default(uuid())
  userId      String
  kind        String // "ganho" | "gasto"
  description String // ex: "Bonus anual", "Conserto do carro"
  category    String? // opcional (ex: Freelance, Venda, Saude, Imposto)
  amount      Decimal  @db.Decimal(12, 2)
  occurredAt  DateTime @db.Date // mes/data do movimento (sem horario; somado por mes em UTC)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@map("extras")
}

// movimentacao do cofre. o cofre e um saldo unico continuo: saldo = soma das entradas
// menos as saidas. entrada = sobra do mes guardada ou ajuste manual; saida = gasto extra
// ou aporte num ativo. source e investmentId ja entram aqui pra Fase 2 (aporte amarrado a
// um investimento) nao precisar de outra migration nesta tabela de dinheiro.
model CofreMovement {
  id           String   @id @default(uuid())
  userId       String
  direction    String // "entrada" | "saida"
  source       String // "sobra" | "gasto_extra" | "ajuste" | "aporte"
  amount       Decimal  @db.Decimal(12, 2)
  notes        String? // descricao livre do movimento
  occurredAt   DateTime @db.Date // data do movimento (sem horario; somado em UTC como o Extra)
  investmentId String? // aporte/resgate amarrado a um ativo (null = movimento manual/sobra)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  investment   Investment? @relation(fields: [investmentId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@map("cofre_movements")
}

// fechamento mensal confirmado pelo usuario (1 por mes). a IA le esta tabela: a diferenca
// entre o que o app calculou (computedSurplus) e o que o usuario confirmou (confirmedSurplus)
// revela ganho/gasto fora do app (o usuario fugiu do gerenciamento). reason e obrigatorio
// quando os dois valores diferem — e o "porque" dessa diferenca.
model MonthClose {
  id               String   @id @default(uuid())
  userId           String
  month            String // "YYYY-MM" do mes fechado
  computedSurplus  Decimal  @db.Decimal(12, 2) // sobra que o app calculou pra aquele mes
  confirmedSurplus Decimal  @db.Decimal(12, 2) // sobra que o usuario confirmou (pode corrigir)
  reason           String? // motivo da correcao, obrigatorio quando confirmed != computed
  confirmedAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId])
  @@map("month_closes")
}

// ancora do cofre por usuario (1 linha). startMonth = primeiro mes que o cofre passou a
// acompanhar; os meses pendentes de fechamento sao contados a partir dele, pra nao pedir
// fechamento de meses anteriores ao inicio do uso do cofre.
model CofreState {
  id         String   @id @default(uuid())
  userId     String   @unique
  startMonth String // "YYYY-MM"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cofre_state")
}

// evento na linha do tempo de um ativo. o valor atual do ativo = soma dos deltas dos eventos
// (saldo_inicial + aportes + rendimentos + ...). guardamos so o delta (variacao) — o valor
// corrente fica cacheado em Investment.value e o "valor apos" e derivado ao listar.
// aporte/resgate criam tambem um CofreMovement (cofreMovementId) na mesma transacao.
model InvestmentEvent {
  id              String     @id @default(uuid())
  investmentId    String
  userId          String // desnormalizado pra escopar consultas por usuario
  type            String // saldo_inicial | aporte | rendimento | resgate | valorizacao | depreciacao
  delta           Decimal    @db.Decimal(12, 2) // variacao do valor do ativo (+ entra, − sai)
  notes           String?
  occurredAt      DateTime   @db.Date
  cofreMovementId String? // movimento do cofre criado junto (aporte/resgate), pra reverter no delete
  createdAt       DateTime   @default(now())
  investment      Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([investmentId, occurredAt])
  @@index([userId])
  @@map("investment_events")
}

// analise da IA (insights) salva por (usuario, hash do input). cache enderecado por
// conteudo: mesmo input => mesmo hash => mesma analise, sem rechamar o Gemini. so
// recalcula quando algum dado que entra no input muda (o hash deixa de bater).
model InsightsCache {
  id        String   @id @default(uuid())
  userId    String
  inputHash String // sha256 do input canonico + ano corrente
  result    Json // o InsightsResponse inteiro (jsonb)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, inputHash])
  @@index([userId])
  @@map("insights_cache")
}

// classificacao de um nome de gasto numa area ampla (Moradia, Transporte, etc), feita
// pela IA a partir do nome. cache por usuario: evita rechamar o Gemini a cada carregamento
// do dashboard. o mesmo nome ja visto vira hit; so nomes novos batem na IA.
model ExpenseAreaMap {
  id        String   @id @default(uuid())
  userId    String
  name      String // nome normalizado (trim + lower + espacos colapsados)
  area      String // uma das areas fixas (ver gastos.schemas.ts)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("expense_area_map")
}

// conexao do usuario com um banco via Pluggy (Open Finance). 1 banco por usuario: o
// pluggyItemId aponta pro "item" no Pluggy (a conexao com aquele banco). guardamos so o
// itemId e o saldo lido; as credenciais do banco NUNCA passam por aqui (o widget do Pluggy
// que autentica). currentBalance = soma das contas tipo BANK no ultimo sync.
model BankConnection {
  id               String    @id @default(uuid())
  userId           String    @unique // um banco por usuario
  provider         String    @default("pluggy")
  pluggyItemId     String // id do item no Pluggy (sensivel: nunca logar/expor a outro user)
  institutionId    String? // id do conector no Pluggy
  institutionName  String? // ex: "Bradesco"
  status           String // status do item: UPDATED | LOGIN_ERROR | WAITING_USER_INPUT | ...
  currentBalance   Decimal   @db.Decimal(12, 2) // soma das contas BANK no ultimo sync (aceita negativo: cheque especial)
  currentBalanceAt DateTime? // quando o saldo foi lido
  lastSyncedAt     DateTime? // ultima sincronizacao forcada (PATCH item)
  lastError        String? // ultima mensagem de erro do Pluggy, se houver
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots        BankBalanceSnapshot[]

  @@map("bank_connections")
}

// saldo de abertura do mes pra ancorar a projecao "inicio -> fim do mes". 1 por (usuario, mes).
// capturado no 1o sync do mes; se a conexao acontecer no meio do mes, partial = true e a UI
// rotula "desde a conexao" em vez de "inicio do mes" (sem fingir precisao que nao temos).
model BankBalanceSnapshot {
  id             String   @id @default(uuid())
  userId         String
  connectionId   String
  month          String // "YYYY-MM"
  openingBalance Decimal  @db.Decimal(12, 2) // saldo no inicio do mes (ou na conexao, se partial)
  partial        Boolean  @default(false) // true = capturado no meio do mes
  capturedAt     DateTime @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection     BankConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId])
  @@map("bank_balance_snapshots")
}
