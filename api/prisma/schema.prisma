generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  expenses    Expense[]
  creditCards CreditCard[]

  @@map("users")
}

// gasto mensal avulso cadastrado pelo usuario (ex: "Aluguel AP")
model Expense {
  id        String   @id @default(uuid())
  userId    String
  name      String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("expenses")
}

// cartao de credito do usuario; entra no gasto mensal so quando includeInMonthly = true
model CreditCard {
  id               String   @id @default(uuid())
  userId           String
  name             String // apelido (ex: "Nubank Roxinho")
  bank             String // banco escolhido (Nubank, Inter, etc)
  avgMonthlySpend  Decimal  @db.Decimal(12, 2)
  includeInMonthly Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("credit_cards")
}
