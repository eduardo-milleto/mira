generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  expenses           Expense[]
  creditCards        CreditCard[]
  incomeSources      IncomeSource[]
  projectionSettings ProjectionSettings?

  @@map("users")
}

// gasto mensal avulso cadastrado pelo usuario (ex: "Aluguel AP")
model Expense {
  id        String   @id @default(uuid())
  userId    String
  name      String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("expenses")
}

// cartao de credito do usuario; entra no gasto mensal so quando includeInMonthly = true
model CreditCard {
  id               String   @id @default(uuid())
  userId           String
  name             String // apelido (ex: "Nubank Roxinho")
  bank             String // banco escolhido (Nubank, Inter, etc)
  avgMonthlySpend  Decimal  @db.Decimal(12, 2)
  includeInMonthly Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("credit_cards")
}

// fonte de renda do usuario usada nas projecoes; itens com startYear no futuro
// sao "novas rendas" que so passam a contar a partir daquele ano
model IncomeSource {
  id              String   @id @default(uuid())
  userId          String
  name            String // ex: "Salario", "Aluguel + Empresa"
  monthlyAmount   Decimal  @db.Decimal(12, 2)
  annualGrowthPct Decimal  @default(0) @db.Decimal(5, 2) // crescimento esperado ao ano
  startYear       Int? // null = ja ativa; ano futuro = renda que ainda vai comecar
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("income_sources")
}

// premissas globais da projecao (1 linha por usuario)
model ProjectionSettings {
  id            String   @id @default(uuid())
  userId        String   @unique
  returnRatePct Decimal  @default(10) @db.Decimal(5, 2) // rendimento ao ano da sobra investida
  horizonYears  Int      @default(5) // quantos anos projetar
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("projection_settings")
}
